{
  "expo": {
    "name": "Loop",
    "slug": "loop-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "loopapp",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.noalani.loop",
      "infoPlist": {
        "NSUserNotificationUsageDescription": "Loop uses notifications to nudge you when you're stuck in a scroll loop.",
        "NSFamilyControlsUsageDescription": "Loop monitors selected apps to detect scroll loops and offer a healthier redirect."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0A",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "package": "com.noalani.loop",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.PACKAGE_USAGE_STATS"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "./plugins/withLoopNative",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#0A0A0A",
          "sounds": []
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0A0A0A",
          "dark": {
            "backgroundColor": "#0A0A0A"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "owner": "REPLACE_WITH_YOUR_EXPO_USERNAME",
    "extra": {
      "eas": {
        "projectId": "REPLACE_WITH_EAS_PROJECT_ID",
      "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "targetName": "LoopActivityMonitor",
                  "bundleIdentifier": "com.noalani.loop.LoopActivityMonitor",
                  "entitlements": {
                    "com.apple.developer.family-controls": true,
                    "com.apple.security.application-groups": [
                      "group.com.noalani.loop"
                    ]
                  }
                }
              ]
            }
          }
        }
      }
    }
  }
}
